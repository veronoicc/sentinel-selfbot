DISCORD_TOKEN=your_account_token_here
API_PORT=48923
API_AUTH_TOKEN=generate_a_random_string_here
DB_PATH=./data/sentinel.db
LOG_LEVEL=info
PROFILE_POLL_INTERVAL_MS=300000
STATUS_POLL_INTERVAL_MS=120000
DAILY_SUMMARY_INTERVAL_MS=3600000

# ── Randomisation ─────────────────────────────────────────────────────────────
#
#   RANDOM_JITTER=true   Adds ±20% jitter to every polling interval so requests
#                        don't fire on a perfectly predictable schedule.
#                        Also randomises the browser/OS fields in the Discord
#                        gateway IDENTIFY payload on each (re)connect.
#
RANDOM_JITTER=false

# ── Database mode ─────────────────────────────────────────────────────────────
#
#   local       – SQLite only. Default. Use on a home server / VPS with a
#                 persistent disk. Supabase vars below are not needed.
#
#   local+cloud – SQLite is the live database; Supabase receives a mirror copy
#                 on the interval below. Good for self-hosted + cloud backup.
#                 ("both" is accepted as a legacy alias for this mode.)
#
#   cloud       – For Railway / Render / Fly.io and any host that wipes the
#                 filesystem on redeploy. On startup, Sentinel pulls all data
#                 from Supabase into a fresh local SQLite before connecting to
#                 Discord. Supabase is the permanent store.
#                 Recommended: set SUPABASE_SYNC_INTERVAL_MS=30000 so you
#                 lose at most 30 seconds of data if the container is killed.
#
DB_MODE=local

# Required when DB_MODE=local+cloud or DB_MODE=cloud
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# How often (ms) to push SQLite data to Supabase.
# local+cloud default: 300000 (5 min)
# cloud recommended:    30000 (30 sec) — limits data loss window on crash/redeploy
SUPABASE_SYNC_INTERVAL_MS=300000

# ── AI Provider ──────────────────────────────────────────────────────────────
#
#   AI_PROVIDER=none      Disables all AI analysis. Default.
#   AI_PROVIDER=gemini    Google Gemini API — RECOMMENDED FREE OPTION
#                         Free tier: 15 RPM and 1 million tokens/day via Google AI Studio.
#                         Get a free key at: https://aistudio.google.com
#                         Set AI_MODEL=gemini-2.0-flash (fast, capable, free tier eligible)
#   AI_PROVIDER=ollama    Local LLM via Ollama (free, private, your PC must stay on)
#                         Expose via ngrok: ngrok http 11434 --host-header="localhost:11434"
#                         Then set AI_BASE_URL to the ngrok https URL + /v1
#   AI_PROVIDER=openai    OpenAI API (pay-per-token, no free tier as of 2025)
#   AI_PROVIDER=anthropic Anthropic Claude API (pay-per-token, no free tier)
#
# ── Gemini (recommended free setup) ──────────────────────────────────────────
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.0-flash
# AI_API_KEY=your_google_ai_studio_key_here
#
# ── Ollama (local, exposed via ngrok) ────────────────────────────────────────
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2
# AI_BASE_URL=https://your-static-domain.ngrok-free.app/v1
# AI_API_KEY=  (leave blank for Ollama)
#
# ── OpenAI ───────────────────────────────────────────────────────────────────
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.openai.com/v1
#
# ── Anthropic ────────────────────────────────────────────────────────────────
# AI_PROVIDER=anthropic
# AI_MODEL=claude-haiku-4-5-20251001
# AI_API_KEY=sk-ant-...
#
AI_PROVIDER=none
AI_MODEL=gemini-2.0-flash
AI_API_KEY=
AI_BASE_URL=http://localhost:11434/v1
AI_ANALYSIS_INTERVAL_MS=86400000
AI_CATEGORIZATION_BATCH_SIZE=50

# ── Backfill ──────────────────────────────────────────────────────────────────
BACKFILL_ENABLED=true
BACKFILL_MAX_DAYS=90
BACKFILL_MAX_MESSAGES_PER_CHANNEL=5000

# ── Alert Improvements ────────────────────────────────────────────────────────
ALERT_DIGEST_MODE=false
ALERT_DIGEST_INTERVAL_MS=900000
ALERT_FATIGUE_THRESHOLD=20
ALERT_WEBHOOK_URL=

# ── Daily Briefs ──────────────────────────────────────────────────────────────
BRIEF_GENERATION_TIME=07:00
